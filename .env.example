# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/restoration_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Storage Paths ---
RAW_STORAGE_PATH=./data/raw
PROCESSED_STORAGE_PATH=./data/processed
MODEL_WEIGHTS_PATH=./weights

# --- GPU Configs (Tuned for 40GB VRAM — A100/A6000) ---
CUDA_VISIBLE_DEVICES=0
USE_GPU=True
VRAM_LIMIT_GB=35

# --- Restoration (DeOldify) ---
DEOLDIFY_RENDER_FACTOR=40
DEOLDIFY_WATERMARK=False

# --- Upscaling (Real-ESRGAN) ---
ESRGAN_SCALE=4
ESRGAN_TILE_SIZE=512
ESRGAN_TILE_PAD=32
ESRGAN_BATCH_SIZE=8
ESRGAN_FP16=True

# --- Shorts Generation ---
SHORTS_NUM_CLIPS=5
SHORTS_DURATION_SEC=45
SHORTS_MIN_SCORE=0.6

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-super-secret-key-change-this

# --- Prefect ---
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_KEY=your-prefect-key-if-cloud

# --- Slurm ---
SLURM_PARTITION=gpu
SLURM_ACCOUNT=restoration_project


MOVIE_LINK=https://archive.org/compress/Night_Of_The_Living_Dead_raw_HD_WS/formats=H.264%20MPEG4,ARCHIVE%20BITTORRENT,METADATA,ITEM%20TILE